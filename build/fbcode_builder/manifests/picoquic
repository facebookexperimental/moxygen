[manifest]
name = picoquic

[git]
repo_url = https://github.com/openmoq/picoquic.git
branch = main

[build]
builder = cmake
subdir = .

[cmake.defines]
PICOQUIC_FETCH_PTLS = ON

[cmake.defines.test=on]
BUILD_TESTING = ON

[cmake.defines.test=off]
BUILD_TESTING = OFF

[dependencies]
openssl

[shipit.pathmap]
